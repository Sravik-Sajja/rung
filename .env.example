OPENAI_API_KEY=
# Routine learner-facing calls default to gpt-5.6-luna in the server adapter.
OPENAI_MODEL=gpt-5.6-luna
# Optional per-feature overrides; use Terra for lower-volume explanation/plan work.
OPENAI_MODEL_DIAGNOSIS=gpt-5.6-terra
OPENAI_MODEL_TUTOR_HINT=
OPENAI_MODEL_ATTEMPT_VERIFICATION=
OPENAI_MODEL_WORK_ANALYSIS=
OPENAI_MODEL_PRACTICE_PLAN=gpt-5.6-terra
OPENAI_MODEL_ITEM_WRAP=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DEMO_MODE=true
