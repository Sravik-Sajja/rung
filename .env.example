OPENAI_API_KEY=
# Routine learner-facing calls default to gpt-5.6-luna in the server adapter.
OPENAI_MODEL=gpt-5.6-luna
# Optional per-feature overrides; use Terra for lower-volume explanation/plan work.
OPENAI_MODEL_DIAGNOSIS=gpt-5.6-terra
OPENAI_MODEL_TUTOR_HINT=
OPENAI_MODEL_ATTEMPT_VERIFICATION=
OPENAI_MODEL_WORK_ANALYSIS=
OPENAI_MODEL_PRACTICE_PLAN=gpt-5.6-terra
OPENAI_MODEL_TEACHER_LESSON=
OPENAI_MODEL_ITEM_WRAP=
# AI cache order per feature: cache_first serves a verified ai_runs entry without
# calling the model; live_first calls the model and uses the cache only on failure.
# Blank keeps the built-in default (see DEFAULT_AI_CACHE_MODES in src/lib/ai/runtime.ts):
# cache_first for tutor hints, diagnosis, and teacher lessons; live_first elsewhere.
# OPENAI_CACHE_MODE sets a global default; a per-feature value wins over it.
OPENAI_CACHE_MODE=
OPENAI_CACHE_MODE_DIAGNOSIS=
OPENAI_CACHE_MODE_TUTOR_HINT=
OPENAI_CACHE_MODE_ATTEMPT_VERIFICATION=
OPENAI_CACHE_MODE_WORK_ANALYSIS=
OPENAI_CACHE_MODE_PRACTICE_PLAN=
OPENAI_CACHE_MODE_TEACHER_LESSON=
OPENAI_CACHE_MODE_ITEM_WRAP=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DEMO_MODE=true

# Seeded curriculum (items, subskills, assignments) is cached in-process for this
# many seconds. `npm run seed` runs out of process and cannot invalidate it, so a
# reseed becomes visible within one window. Set 0 to disable while editing seed data.
RUNG_CURRICULUM_CACHE_SECONDS=3600
RUNG_CURRICULUM_CACHE_MAX_ENTRIES=500
